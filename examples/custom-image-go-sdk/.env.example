# 复制为 .env 后填写真实值
TENCENTCLOUD_SECRET_ID=your-secret-id
TENCENTCLOUD_SECRET_KEY=your-secret-key
TENCENTCLOUD_REGION=ap-guangzhou

# 已创建的自定义工具名称（custom 类型）
AGS_TOOL_NAME=custom-dev

# ==========================================
# 启动时覆盖配置（CustomConfiguration）
# 以下全部可选，AGS_RUNTIME_IMAGE 非空才生效
# ==========================================

# 镜像地址（为空则使用工具默认镜像）
AGS_RUNTIME_IMAGE=tkeai.tencentcloudcr.com/your-namespace/your-image:latest

# enterprise 或 personal
AGS_RUNTIME_IMAGE_REGISTRY_TYPE=enterprise

# 启动命令，JSON 字符串数组
AGS_CUSTOM_COMMAND=["/init"]

# 启动参数，JSON 字符串数组
AGS_CUSTOM_ARGS=["sleep","infinity"]

# 端口配置，JSON 数组
AGS_CUSTOM_PORTS=[{"Name":"http","Protocol":"TCP","Port":49999},{"Name":"envd","Protocol":"TCP","Port":49983}]

# ==========================================
# 探针配置（健康检查）
# AGS_PROBE_PATH 非空时生效
# ==========================================
AGS_PROBE_PATH=/health
AGS_PROBE_PORT=49999
AGS_PROBE_SCHEME=HTTP
AGS_PROBE_READY_TIMEOUT_MS=30000
AGS_PROBE_TIMEOUT_MS=1000
AGS_PROBE_PERIOD_MS=1000
AGS_PROBE_SUCCESS_THRESHOLD=1
AGS_PROBE_FAILURE_THRESHOLD=100
